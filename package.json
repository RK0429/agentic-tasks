{
  "name": "@rk0429/agentic-tasks",
  "version": "0.2.0",
  "description": "AI agent task management system with MCP server, SQLite storage, and orchestration protocol",
  "type": "module",
  "license": "Apache-2.0",
  "author": "RK0429",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RK0429/agentic-tasks.git"
  },
  "homepage": "https://github.com/RK0429/agentic-tasks",
  "bugs": {
    "url": "https://github.com/RK0429/agentic-tasks/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server/index.d.ts",
      "import": "./dist/mcp-server/index.js"
    }
  },
  "bin": {
    "agentic-tasks": "dist/cli/tasks.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp -r src/db/migrations dist/db/migrations",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "tasks": "tsx src/cli/tasks.ts",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "cron-parser": "^5.4.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.17",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.0.8"
  },
  "packageManager": "pnpm@10.6.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
